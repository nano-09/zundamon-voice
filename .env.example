# ── Required ─────────────────────────────────────

# ── Supabase (Required for Database/2FA) ─────────
# Get this from your Supabase Project Settings > API
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_service_role_key_here

# ── Discord ───────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here
# Application (client) ID from the same page
CLIENT_ID=your_client_id_here
# Your personal Discord user ID (enable Developer Mode > right-click yourself > Copy ID)
OWNER_DISCORD_ID=your_discord_id_here

# ── Email / SMTP ──────────────────────────────────
OWNER_EMAIL=your_email_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email_here
SMTP_PASS=your_smtp_pass_here

# ── VoiceVox (TTS Engine) ─────────────────────────
# Default if running VoiceVox locally
VOICEVOX_URL=http://localhost:50021
# Speaker ID: 3 = ずんだもん (normal)
VOICEVOX_SPEAKER=3